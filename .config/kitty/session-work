# This is an example session template for kitty

# Set the working directory for windows in the current tab
cd ~/
# Create a window (title sets the tab title)
# We pass the desired buffer name directly to avoid interactive prompts
launch --title cli emacsclient -nw --eval "(tl/ghostel-new-named \"*ghostel-cli*\")"

# Create a new tab
new_tab workspace
cd ~/desktop/workspace
# Launch yazi in that directory
launch --title workspace emacsclient -nw --eval "(tl/ghostel-new-yazi)"

# Create a new tab
new_tab cheatsheets
cd ~
launch --title cheatsheets emacsclient -nw --eval "(tl/ghostel-new-named \"*ghostel-cheatsheets*\")"

# Create a new tab
new_tab notes
cd ~
launch --title notes emacsclient -nw --eval "(tl/ghostel-new-named \"*ghostel-notes*\")"
