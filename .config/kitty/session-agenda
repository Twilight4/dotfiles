# Set the layout in this tab
layout tall
# Set the working directory for windows in the current tab
cd ~/
# Create a window (title sets the tab title)
launch --title agenda sh -c 'zsh -c "emacsclient -nw --eval \"(progn (tl/org-agenda-o) (tl/split-window-right))\" ; exec zsh"'
# Focus the current tab
focus

# Create a new tab
new_tab scratchpad
# Set the layout in this tab
layout tall
# Set the working directory for windows in the current tab
cd ~/
# Create a window (title sets the tab title)
launch --title scratchpad sh -c 'zsh -c "emacsclient -nw -e \"(tl/switch-to-or-create-org-buffer)\" ; exec zsh"'

